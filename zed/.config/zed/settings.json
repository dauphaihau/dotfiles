// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  /* Duplicated key auto-commented: "agent": {
    "default_profile": "ask",
    "model_parameters": []
  }, */
  "agent_buffer_font_size": 11.0,
  "diff_view_style": "unified",
  "zoomed_padding": true,
  "tab_bar": {
    "show_tab_bar_buttons": true
  },
  "ui_font_family": ".ZedSans",
  "buffer_line_height": {
    "custom": 1.2999999523162842
  },
  "buffer_font_weight": 400.0,
  "debugger": {
    "dock": "left"
  },
  "git_panel": {
    "tree_view": true
  },
  "buffer_font_family": "JetBrainsMono Nerd Font Mono",
  "icon_theme": {
    "mode": "system",
    "light": "Base Charmed Icons",
    "dark": "Material Icon Theme"
  },
  "agent": {
    "play_sound_when_agent_done": true,
    "tool_permissions": {
      "tools": {
        "terminal": {
          "always_allow": [
            {
              "pattern": "^git\\s+diff(\\s|$)"
            }
          ]
        }
      }
    },
    "favorite_models": [
      {
        "provider": "zed.dev",
        "model": "gpt-5.2",
        "enable_thinking": false
      }
    ],
    "dock": "right",
    "default_profile": "write",
    "default_model": {
      "effort": "high",
      "enable_thinking": true,
      "provider": "zed.dev",
      "model": "claude-sonnet-4-6"
    }
  },
  "vim_mode": true,
  "ui_font_size": 15.0,
  "buffer_font_size": 12.0,
  "theme": {
    "mode": "system",
    "light": "GitHub Light Classic",
    "dark": "Lotus Dark"
  },
  "autosave": {
    "after_delay": {
      "milliseconds": 1000 // Adjust this: e.g., 500 for faster, 2000 for slower
    }
  }
}
