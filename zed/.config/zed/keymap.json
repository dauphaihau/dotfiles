[
  // ─── Tab / Pane Navigation ───────────────────────────────────────────────────
  {
    "context": "Editor && VimControl && !VimWaiting && !menu",
    "bindings": {
      "tab": "pane::ActivatePreviousItem",
      "shift-tab": "pane::ActivateNextItem",
      "q": "pane::CloseActiveItem",
      "shift-q": "pane::ReopenClosedItem",
      ",f": "editor::Format",
      "cmd-shift-f": "editor::OpenSelectedFilename",
    },
  },
  {
    "context": "((VimControl && !menu) || (!Editor && !Terminal))",
    "bindings": {
      ", w": "pane::CloseAllItems",
    },
  },

  // ─── Pane Resize ─────────────────────────────────────────────────────────────
  {
    "context": "((VimControl && !menu) || (!Editor && !Terminal))",
    "bindings": {
      "alt-a": "vim::ResizePaneLeft",
      "alt-d": "vim::ResizePaneRight",
    },
  },

  // ─── Workspace ───────────────────────────────────────────────────────────────
  {
    "context": "Workspace",
    "bindings": {
      "cmd-9": "git_panel::ToggleFocus",
    },
  },
  {
    "bindings": {
      "cmd-l": "workspace::ToggleLeftDock",
    },
  },

  // ─── File Finder ─────────────────────────────────────────────────────────────
  {
    "bindings": {
      "cmd-e": "file_finder::Toggle",
    },
  },
  {
    "context": "Workspace",
    "bindings": {
      "cmd-shift-e": "file_finder::Toggle",
    },
  },
  {
    "context": "KeymapEditor",
    "bindings": {
      "cmd-e": "zed::OpenKeymapFile",
    },
  },

  // ─── Project Panel ────────────────────────────────────────────────────────────
  {
    "context": "AgentPanel",
    "bindings": {
      "cmd-1": "project_panel::ToggleFocus",
    },
  },
  {
    "context": "!ContextEditor > (Editor && mode == full)",
    "bindings": {
      "cmd-1": "pane::RevealInProjectPanel",
    },
  },
  {
    "context": "Workspace",
    "bindings": {
      "cmd-1": "project_panel::ToggleFocus",
    },
  },
  {
    "context": "ProjectPanel",
    "bindings": {
      "shift-backspace": "project_panel::Delete",
      "alt-n": "project_panel::NewDirectory",
    },
  },
  {
    "context": "(ProjectPanel && not_editing)",
    "bindings": {
      "n": "project_panel::NewFile",
      "r": "project_panel::Rename",
    },
  },

  // ─── Search ───────────────────────────────────────────────────────────────────
  {
    "context": "ProjectSearchBar",
    "bindings": {
      "cmd-shift-f": "search::FocusSearch",
    },
  },
  {
    "bindings": {
      "cmd-shift-f": "pane::DeploySearch",
    },
  },

  // ─── Editor ───────────────────────────────────────────────────────────────────
  {
    "context": "Editor",
    "bindings": {
      ", f": "editor::Format",
    },
  },
  {
    "context": "ContextEditor > Editor",
    "bindings": {
      "cmd-s": null,
    },
  },
  {
    "context": "Workspace",
    "bindings": {
      "cmd-s": null,
    },
  },
  {
    "context": "Editor",
    "bindings": {
      "cmd-s": [
        "editor::SelectNext",
        {
          "replace_newest": false,
        },
      ],
    },
  },

  // ─── Code Navigation (Vim) ────────────────────────────────────────────────────
  {
    "context": "(VimControl && !menu)",
    "bindings": {
      ", d": "editor::GoToDefinition",
      ", r": "editor::FindAllReferences",
      "space z c": "editor::FoldAll",
    },
  },
  {
    "context": "((vim_mode == helix_normal || vim_mode == helix_select) && !menu)",
    "bindings": {
      ", r": "editor::FindAllReferences",
    },
  },
  {
    "context": "Editor",
    "bindings": {
      "space z o": "editor::UnfoldAll",
    },
  },
  {
    "context": "((vim_mode == normal || vim_mode == helix_normal) && !menu && !search && !buffer_search)",
    "bindings": {
      "enter": "vim::InsertEmptyLineBelow",
    },
  },

  // ─── Agent Panel ──────────────────────────────────────────────────────────────
  {
    "context": "AgentPanel",
    "bindings": {
      "cmd-shift-i": "agent::ToggleNewThreadMenu",
      "cmd-i": null,
      "cmd-shift-m": "agent::ToggleModelSelector",
    },
  },
  {
    "context": "(AgentPanel && acp_thread)",
    "bindings": {
      "cmd-shift-i": "agent::NewThread",
    },
  },
  {
    "context": "(Editor && mode == full)",
    "bindings": {
      "cmd-shift-l": "agent::AddSelectionToThread",
    },
  },
  {
    "context": "AcpThread > Editor",
    "bindings": {
      "cmd-i": null,
      "cmd-.": "agent::ToggleProfileSelector",
      "cmd-shift-c": "agent::OpenAddContextMenu",
    },
  },
  {
    "context": "((vim_mode == normal || vim_mode == visual) || vim_mode == operator)",
    "bindings": {
      "shift-enter": "vim::InsertEmptyLineAbove",
    },
  },
  {
    "context": "BufferSearchBar",
    "bindings": {
      "enter": "search::SelectNextMatch",
      "shift-enter": "search::SelectPreviousMatch",
    },
  },
  {
    "context": "Workspace",
    "unbind": {
      "cmd-shift-b": "outline_panel::ToggleFocus"
    }
  },
  {
    "context": "Workspace",
    "bindings": {
      "cmd-shift-b": "git::Branch"
    }
  },
  {
    "context": "Workspace",
    "unbind": {
      "ctrl-cmd-b": "git::Branch"
    }
  },
  {
    "context": "KeymapEditor",
    "unbind": {
      "cmd-shift-c": "keymap_editor::CopyContext"
    }
  },
  {
    "bindings": {
      "cmd-shift-c": "editor::CopyPath"
    }
  },
  {
    "bindings": {
      "cmd-shift-c": "editor::CopyRelativePath"
    }
  },
  {
    "context": "VimControl && !menu",
    "unbind": {
      "ctrl-w ctrl-]": "editor::GoToDefinitionSplit"
    }
  }
]
