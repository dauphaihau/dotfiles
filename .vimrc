set scrolloff=5
set ignorecase
set smartcase
set ideajoin "Shift+J to join lines
set commentary "comment/uncomment code . e.g gc1k ( comment current and above line )
set incsearch
set nospell
set surround "easily CRUD parentheses, brackets, .. e.g cs"' for "Hello world!" -> 'Hello world!'
set multiple-cursors
set ReplaceWithRegister
set foldmethod=manual
set clipboard=unnamedplus
set number          " show absolute number on current line
set relativenumber  " show relative numbers on others

nnoremap <leader>zc zM

" Press Enter in normal mode to add a new empty line below (without entering insert mode)
nnoremap <CR> o<Esc>


