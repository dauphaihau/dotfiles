{
  "profiles": [
    {
      "complex_modifications": {
        "rules": [
          {
            "description": "Disable Cmd+Shift+H & Cmd+Shift+K in Notion",
            "enabled": false,
            "manipulators": [
              {
                "conditions": [
                  {
                    "bundle_identifiers": ["^notion\\.id$"],
                    "type": "frontmost_application_if"
                  }
                ],
                "from": {
                  "key_code": "h",
                  "modifiers": {
                    "mandatory": ["command", "shift"],
                    "optional": ["any"]
                  }
                },
                "to": [{ "key_code": "vk_none" }],
                "type": "basic"
              },
              {
                "conditions": [
                  {
                    "bundle_identifiers": ["^notion\\.id$"],
                    "type": "frontmost_application_if"
                  }
                ],
                "from": {
                  "key_code": "k",
                  "modifiers": {
                    "mandatory": ["command", "shift"],
                    "optional": ["any"]
                  }
                },
                "to": [{ "key_code": "vk_none" }],
                "type": "basic"
              }
            ]
          },
          {
            "description": "Map Left Option plus h/j/k/l to Arrows",
            "enabled": true,
            "manipulators": [
              {
                "from": {
                  "key_code": "h",
                  "modifiers": {
                    "mandatory": ["left_option"],
                    "optional": ["any"]
                  }
                },
                "to": [{ "key_code": "left_arrow" }],
                "type": "basic"
              },
              {
                "from": {
                  "key_code": "j",
                  "modifiers": {
                    "mandatory": ["left_option"],
                    "optional": ["any"]
                  }
                },
                "to": [{ "key_code": "down_arrow" }],
                "type": "basic"
              },
              {
                "from": {
                  "key_code": "k",
                  "modifiers": {
                    "mandatory": ["left_option"],
                    "optional": ["any"]
                  }
                },
                "to": [{ "key_code": "up_arrow" }],
                "type": "basic"
              },
              {
                "from": {
                  "key_code": "l",
                  "modifiers": {
                    "mandatory": ["left_option"],
                    "optional": ["any"]
                  }
                },
                "to": [{ "key_code": "right_arrow" }],
                "type": "basic"
              }
            ]
          },
          {
            "description": "Option+O => Right Click (Only in Zed)",
            "manipulators": [
              {
                "conditions": [
                  {
                    "bundle_identifiers": ["^dev\\.zed\\.Zed$"],
                    "type": "frontmost_application_if"
                  }
                ],
                "from": {
                  "key_code": "o",
                  "modifiers": {
                    "mandatory": ["option"],
                    "optional": ["any"]
                  }
                },
                "to": [{ "pointing_button": "button2" }],
                "type": "basic"
              }
            ]
          },
          {
            "description": "Delete => Cmd+backspace (Delete) (Only in Finder)",
            "manipulators": [
              {
                "conditions": [
                  {
                    "bundle_identifiers": ["^com.apple.finder"],
                    "type": "frontmost_application_if"
                  }
                ],
                "from": {
                  "key_code": "delete_forward",
                  "modifiers": { "optional": ["any"] }
                },
                "to": [
                  {
                    "key_code": "delete_or_backspace",
                    "modifiers": ["left_command"]
                  }
                ],
                "type": "basic"
              }
            ]
          }
        ]
      },
      "devices": [
        {
          "identifiers": {
            "is_keyboard": true,
            "is_pointing_device": true,
            "product_id": 591,
            "vendor_id": 1452
          },
          "ignore": false
        }
      ],
      "fn_function_keys": [
        {
          "from": { "key_code": "f6" },
          "to": [{ "key_code": "f6" }]
